{
  "entities": {
    "User": {
      "title": "User",
      "description": "Public user profile and role",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["customer", "seller", "admin"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "createdAt"]
    },
    "UserPrivate": {
      "title": "User Private Data",
      "description": "PII for the user",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["email"]
    },
    "Shop": {
      "title": "Shop",
      "description": "Seller shop details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "banned"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "status", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A product sold by a shop",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "shopId": { "type": "string" },
        "sellerId": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "draft"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock", "shopId", "sellerId", "images", "status", "createdAt", "updatedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a customer",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "shopId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "sellerId", "shopId", "totalAmount", "status", "createdAt", "updatedAt"]
    },
    "OrderItem": {
       "title": "OrderItem",
       "description": "Item in an order",
       "type": "object",
       "properties": {
         "productId": { "type": "string" },
         "quantity": { "type": "number" },
         "price": { "type": "number" }
       },
       "required": ["productId", "quantity", "price"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Public user profiles"
    },
    "/users/{userId}/private/{docId}": {
      "schema": { "$ref": "#/entities/UserPrivate" },
      "description": "Private user information (docId = 'info')"
    },
    "/shops/{shopId}": {
      "schema": { "$ref": "#/entities/Shop" },
      "description": "Shops"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products list"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders list"
    },
    "/orders/{orderId}/items/{itemId}": {
      "schema": { "$ref": "#/entities/OrderItem" },
      "description": "Items in an order"
    }
  }
}
